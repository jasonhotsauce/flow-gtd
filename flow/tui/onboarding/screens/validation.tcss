/* Validation - Ops style */

#validation-subtitle {
    color: #b8c6d8;
    margin-bottom: 1;
}

#validation-status {
    width: 100%;
    min-height: 12;
    align: center middle;
}

#loading-state,
#success-state,
#error-state {
    width: 100%;
    align: center middle;
}

#loading-text,
#success-detail,
#error-detail,
#validation-title {
    color: #b8c6d8;
    text-align: center;
}

#success-icon,
#success-text {
    color: #43b581;
    text-style: bold;
    text-align: center;
}

#error-icon,
#error-text {
    color: #e36d6d;
    text-style: bold;
    text-align: center;
}

#validation-actions {
    align: center middle;
    margin-top: 1;
    padding-top: 1;
    border-top: solid #253241;
}

#back-btn,
#retry-btn {
    margin-right: 1;
}
